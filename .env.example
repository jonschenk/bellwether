# AI provider for stock analysis:
#   ollama     - free local model, runs on your Mac (default)
#   anthropic  - Claude API (paid, needs ANTHROPIC_API_KEY)
#   none       - skip AI analysis, technicals only
AI_PROVIDER=ollama

# Which local model Ollama uses. llama3.2:3b is light enough for 8 GB Macs.
# If you have 16+ GB RAM, llama3.1:8b gives better analysis.
OLLAMA_MODEL=llama3.2:3b

# Only needed if AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
